{
  "name": "planforge",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Requirement Analysis and Solution Generation",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter planforge-web dev",
    "dev:backend": "pnpm --filter planforge-api dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter planforge-web build",
    "build:backend": "pnpm --filter planforge-api build",
    "install:all": "pnpm install"
  },
  "keywords": [
    "ai",
    "requirement-analysis",
    "solution-generator",
    "planforge"
  ],
  "author": "",
  "license": "MIT"
}
