# Backend Environment Configuration Example
# Copy this file to .env.dev or .env.prod and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Email Configuration
# ====================
# Choose one of the following email providers
# ====================

# Option 1: QQ Mail (Recommended for China)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@qq.com
SMTP_PASS=your-authorization-code
EMAIL_FROM=PlanForge <your-email@qq.com>

# Option 2: 163 Mail
# SMTP_HOST=smtp.163.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@163.com
# SMTP_PASS=your-authorization-code
# EMAIL_FROM=PlanForge <your-email@163.com>

# Option 3: Gmail (Recommended for overseas)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=PlanForge <your-email@gmail.com>

# JWT Configuration
# Generate a new secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-new-jwt-secret-here
